# ── Unified AI Provider Configuration ──────────────────────────────────
# Set these to configure the AI provider without CLI flags.
# Uncomment and fill in the ones you need.

# Provider: openai_compat | gemini | ollama | mock
# AI_PROVIDER=openai_compat

# Model name (provider-specific):
#   openai_compat:   gpt-4o, gpt-4o-mini, etc.
#   gemini:          gemini-2.5-flash-lite, gemini-2.0-flash, etc.
#   ollama:          qwen3-vl:4b, gemma3:12b, llama3.2-vision, etc.
# AI_MODEL=gpt-4o-mini

# API key (for openai_compat and gemini providers)
# AI_API_KEY=sk-your-key-here

# Base URL (for openai_compat provider only)
#   OpenAI:        https://api.openai.com/v1
#   Groq:          https://api.groq.com/openai/v1
#   Together:      https://api.together.xyz/v1
#   Fireworks:     https://api.fireworks.ai/inference/v1
#   Gemini (OAI):  https://generativelanguage.googleapis.com/v1beta/openai
# AI_BASE_URL=https://api.openai.com/v1


# ── Provider-Specific Overrides (optional) ─────────────────────────────
# These override the unified vars above for specific providers.

# GEMINI_API_KEY=your-gemini-key
# GEMINI_MODEL=gemini-2.5-flash-lite

# OLLAMA_MODEL=qwen3-vl:4b
# OLLAMA_BASE_URL=http://localhost:11434

# OPENAI_COMPAT_MODEL=gpt-4o-mini
# OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
# OPENAI_COMPAT_API_KEY=sk-your-key-here
